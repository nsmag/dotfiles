{
  "$schema": "https://opencode.ai/config.json",
  "theme": "rosepine",
  "autoupdate": "notify",
  "share": "disabled",
  "permission": {
    "bash": {
      "*": "allow",
    },
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "ask",
      },
    },
    "general": {
      "model": "github-copilot/claude-haiku-4.5",
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
    },
  },
  "plugin": ["@franlol/opencode-md-table-formatter@0.0.3"],
}
